<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GWAS Report — {{ trait_col }}</title>
<style>
  :root {
    --blue: #0072B2;
    --orange: #E69F00;
    --green: #009E73;
    --red: #D55E00;
    --purple: #CC79A7;
    --bg: #fafafa;
    --border: #ddd;
  }
  * { box-sizing: border-box; }
  body {
    font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    max-width: 1100px;
    margin: 0 auto;
    padding: 20px 40px;
    background: #fff;
    color: #333;
    line-height: 1.6;
  }
  h1 { color: var(--blue); border-bottom: 3px solid var(--blue); padding-bottom: 8px; }
  h2 { color: #444; border-bottom: 1px solid var(--border); padding-bottom: 4px; margin-top: 2em; }
  h3 { color: #555; }
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    margin: 16px 0;
  }
  .summary-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    text-align: center;
  }
  .summary-card .value {
    font-size: 1.8em;
    font-weight: 700;
    color: var(--blue);
  }
  .summary-card .label {
    font-size: 0.9em;
    color: #666;
    margin-top: 4px;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 12px 0;
    font-size: 0.9em;
  }
  th, td {
    border: 1px solid var(--border);
    padding: 8px 12px;
    text-align: left;
  }
  th { background: var(--bg); font-weight: 600; }
  tr:nth-child(even) { background: #f9f9f9; }
  .figure-container {
    text-align: center;
    margin: 20px 0;
  }
  .figure-container img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .figure-caption {
    font-size: 0.85em;
    color: #666;
    margin-top: 6px;
    font-style: italic;
  }
  .metadata {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85em;
    white-space: pre-wrap;
    overflow-x: auto;
  }
  .footer {
    margin-top: 40px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    font-size: 0.8em;
    color: #999;
    text-align: center;
  }
  @media print {
    body { max-width: 100%; padding: 10px; }
    .figure-container img { max-width: 80%; }
  }
</style>
</head>
<body>

<h1>GWAS Report: {{ trait_col }}</h1>
<p><strong>Generated:</strong> {{ date }} &nbsp;|&nbsp; <strong>Framework:</strong> TRACE v1.0.0</p>

<!-- ── Executive Summary ─────────────────────────── -->
<h2>Executive Summary</h2>
<div class="summary-grid">
  <div class="summary-card">
    <div class="value">{{ n_samples }}</div>
    <div class="label">Samples</div>
  </div>
  <div class="summary-card">
    <div class="value">{{ n_snps }}</div>
    <div class="label">SNPs (post-QC)</div>
  </div>
  {% if lambda_gc is not none %}
  <div class="summary-card">
    <div class="value">{{ "%.3f"|format(lambda_gc) }}</div>
    <div class="label">&lambda;<sub>GC</sub></div>
  </div>
  {% endif %}
  <div class="summary-card">
    <div class="value">{{ n_significant }}</div>
    <div class="label">Significant ({{ sig_label }})</div>
  </div>
</div>

<!-- ── QC Summary ────────────────────────────────── -->
<h2>Quality Control Summary</h2>
<table>
  <tr><th>Metric</th><th>Value</th></tr>
  {% for key, val in qc_snp.items() %}
  <tr><td>{{ key }}</td><td>{{ val }}</td></tr>
  {% endfor %}
</table>
{% if info_field %}
<p><strong>Imputation quality field detected:</strong> {{ info_field }}</p>
{% endif %}

<!-- ── Figures ────────────────────────────────────── -->
{% for fig_name, fig_b64 in figures.items() %}
<h2>{{ fig_name | replace("_", " ") | replace(".png", "") }}</h2>
<div class="figure-container">
  <img src="data:image/png;base64,{{ fig_b64 }}" alt="{{ fig_name }}">
</div>
{% endfor %}

<!-- ── Top Hits ───────────────────────────────────── -->
<h2>Top Hits</h2>
{% if top_hits_html %}
{{ top_hits_html | safe }}
{% else %}
<p>No significant hits at FDR &lt; 0.05.</p>
{% endif %}

<!-- ── PC Selection ──────────────────────────────── -->
{% if pc_selection_html %}
<h2>Principal Component Selection (&lambda;-based)</h2>
<p>MLM GWAS was run at each PC count; the PC count with &lambda;<sub>GC</sub> closest to 1.0 was selected.</p>
{{ pc_selection_html | safe }}
{% endif %}

<!-- ── Metadata ───────────────────────────────────── -->
<h2>Run Metadata</h2>
<div class="metadata">{{ metadata_json | safe }}</div>

<div class="footer">
  Generated by TRACE &mdash; Trait Resolution and Candidate Evaluation
</div>

</body>
</html>
